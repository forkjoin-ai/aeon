{
  "name": "fork-race-collapse-companion",
  "version": "1.0.0",
  "description": "Reproducible companion tests for 'Fork/Race/Collapse Is All You Need' (arXiv manuscript)",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:gate1": "bun ./scripts/gate1-wallclock-matrix.ts --assert",
    "bench:gate1": "bun ./scripts/gate1-wallclock-matrix.ts",
    "test:gate1:hard": "bun ./scripts/gate1-hard-workloads.ts --assert",
    "bench:gate1:hard": "bun ./scripts/gate1-hard-workloads.ts",
    "test:gate2": "bun ./scripts/gate2-protocol-corpus.ts --assert",
    "bench:gate2": "bun ./scripts/gate2-protocol-corpus.ts",
    "test:gate3": "bun ./scripts/gate3-compression-corpus.ts --assert",
    "bench:gate3": "bun ./scripts/gate3-compression-corpus.ts",
    "test:gate4": "bun ./scripts/gate4-rqr-holdout.ts --assert",
    "bench:gate4": "bun ./scripts/gate4-rqr-holdout.ts",
    "test:gate5": "bun ./scripts/gate5-bio-effect-size.ts --assert",
    "bench:gate5": "bun ./scripts/gate5-bio-effect-size.ts",
    "test:quantum-ablation": "bun ./scripts/quantum-recombination-ablation.ts --assert",
    "bench:quantum-ablation": "bun ./scripts/quantum-recombination-ablation.ts",
    "test:toy-attention-ablation": "bun ./scripts/toy-attention-fold-ablation.ts --assert",
    "bench:toy-attention-ablation": "bun ./scripts/toy-attention-fold-ablation.ts",
    "test:gnosis-fold-training": "bun ./scripts/gnosis-fold-training-benchmark.ts --assert",
    "bench:gnosis-fold-training": "bun ./scripts/gnosis-fold-training-benchmark.ts",
    "test:ch17-figure": "bun ./scripts/ch17-correspondence-boundary-figure.ts --assert",
    "bench:ch17-figure": "bun ./scripts/ch17-correspondence-boundary-figure.ts",
    "test:formal:parser": "bun ./scripts/validate-formal-artifacts.ts",
    "test:formal:lean": "bun ./scripts/run-lean-theorems.ts",
    "test:formal:shootoff": "bun ./scripts/formal-parser-shootoff.ts",
    "test:formal:equivalence": "bun ./scripts/formal-parser-equivalence.ts",
    "test:formal": "bun run test:formal:parser && bun run test:formal:equivalence && bun run test:formal:lean && bash ./scripts/run-formal-verification.sh",
    "test:all": "bun run test && bun run test:formal",
    "test:watch": "vitest",
    "test:pipeline": "vitest run -t 'Pipeline'",
    "test:flow": "vitest run -t 'Flow Protocol'",
    "test:compression": "vitest run -t 'Topological Compression'",
    "test:shootoff": "vitest run -t 'Shootoff'",
    "test:queueing": "vitest run -t 'Queueing Theory'",
    "test:thermodynamics": "vitest run -t 'Thermodynamics'"
  },
  "devDependencies": {
    "@affectively/aeon-logic": "file:../../../../../aeon-logic",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
